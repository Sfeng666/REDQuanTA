# REDQuanTA Snakemake Workflow
import os
from pathlib import Path
configfile: "config/config_detect.yaml"
WORKFLOW_DIR = Path(workflow.basedir)
SCRIPTS_DIR = WORKFLOW_DIR / "scripts"
OUTPUT_DIR = config.get("output_dir", "results")
include: "rules/fst_input.smk"
include: "rules/detect.smk"
include: "rules/evaluate.smk"
include: "rules/sample_struct_comparison.smk"
rule all:
    input:
        f"{OUTPUT_DIR}/qst_results.csv"
def _evaluate_all_inputs():
    _od = config.get("output_dir", "results/evaluate")
    _chrs = config.get("chromosomes", ["autosomes"])
    _combos = config.get("summary_stats_combos", ["QST,F_within_pop"])
    inputs = expand(
        "{od}/{chr}/tpr_fpr_matrix_{chr}_{stats}.csv",
        od=_od, chr=_chrs,
        stats=[s.replace(",", "_") for s in _combos]
    )
    inputs.append(f"{_od}/combined_model_ranking.csv")
    if config.get("sample_structures", []):
        _cs = config.get("comparison_stats", _combos[0]).replace(",", "_")
        inputs.append(f"{_od}/sample_struct_comparison_{_cs}/plots/done.txt")
    return inputs
rule evaluate_all:
    input: _evaluate_all_inputs()
rule clean:
    shell:
        "rm -rf {OUTPUT_DIR}/*"
